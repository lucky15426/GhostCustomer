# ============================================================================
# Ghost Customer AI — Python engine environment
# Copy to .env. EVERYTHING IS OPTIONAL: with no keys the engine runs on the
# deterministic seeded mock engine and the full pipeline still works offline.
# ============================================================================

# --- AI (recommended for "real" analysis + report narrative) ---------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Website crawling (optional; falls back to plain fetch, then mock) ------
# https://www.firecrawl.dev (free tier)
FIRECRAWL_API_KEY=

# --- Wiring back to the Next.js frontend ------------------------------------
# Set PYTHON_ENGINE_URL in the Next.js app's .env.local to this engine's URL
# (e.g. http://localhost:8000) to enable the /py/* rewrite proxy.
PYTHON_ENGINE_URL=http://localhost:8000

# --- Supabase (optional persistence + auth; not required by the engine) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
