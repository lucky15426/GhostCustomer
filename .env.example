# ============================================================================
# Ghost Customer AI — environment
# Copy to .env.local. EVERYTHING IS OPTIONAL: with no keys the app runs on the
# deterministic mock engine and the full demo still works end to end.
# ============================================================================

# --- AI (recommended for "real" analysis + report narrative) ---------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Groq (recommended for TEXT analysis/report — fast, generous free quota) -
# Get a free key at https://console.groq.com/keys
# When set, website analysis + report + auto-fix use Groq; Gemini is the fallback.
# Groq Vision (Llama 4) is also the UI Roast fallback when Gemini Vision is busy.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Website crawling (optional; falls back to plain fetch, then mock) ------
# https://www.firecrawl.dev (free tier)
FIRECRAWL_API_KEY=

# --- Optional: route runs through the Python FastAPI + LangGraph engine -----
# e.g. http://localhost:8000  (enables /py/* proxy)
PYTHON_ENGINE_URL=

# --- Supabase (optional run persistence + user authentication) -------------
# Project URL + anon/publishable key power client-side sign-in/sign-up.
# The service-role key is server-only and used for durable run storage.
# With these unset the app stays fully open (no sign-in wall) and uses memory.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
